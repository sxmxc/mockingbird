{
  "name": "mockingbird-admin",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "mcp:vuetify": "mcp",
    "mcp:vuetify:http": "mcp --transport=http --port=3232 --host=0.0.0.0 --stateless"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vuetify/v0": "0.1.6",
    "axios": "^1.5.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@typescript-eslint/eslint-plugin": "^7.12.1",
    "@typescript-eslint/parser": "^7.12.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vuetify/mcp": "0.5.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^28.1.0",
    "sass": "^1.89.2",
    "typescript": "^5.6.2",
    "vite": "^5.3.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
